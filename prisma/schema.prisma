// Prisma schema for the portfolio tracker.
//
// Local dev uses SQLite (zero setup). For the deployed version on Vercel,
// switch `provider` to "postgresql" and point DATABASE_URL at your Neon
// database (see DEPLOY.md). The models below are portable across both.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  holdings     Holding[]
}

model Holding {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  symbol      String // e.g. "NTPC" (display ticker)
  name        String? // optional friendly name
  exchange    String   @default("NSE") // "NSE" | "BSE"
  yahooSymbol String // e.g. "NTPC.NS" — what we query Yahoo with

  buyPrice    Float
  quantity    Float

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}
