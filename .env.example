# Copy to .env and fill in.

# Local dev: SQLite. Production: a Postgres connection string from Neon.
DATABASE_URL="file:./dev.db"

# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me"

# "true" to allow new sign-ups, "false" to lock it down.
ALLOW_REGISTRATION="true"

# Resend API key for emailing password-reset codes (https://resend.com).
# Without it, the "Forgot password?" email flow is disabled.
RESEND_API_KEY=""
# Optional custom sender once you've verified a domain in Resend.
# RESET_EMAIL_FROM="Portfolio Tracker <noreply@yourdomain.com>"
